# Secrets
.env
.env.*
!.env.example

# macOS
.DS_Store
**/.DS_Store
._*

# Audio/video recordings (too large for git)
*.mp3
*.mp4

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Office temp files
~$*.xlsx
~$*.docx
*.tmp

# Timestamped manual backups (e.g. `foo.docx.bak-2026-04-21`) — keep local, never commit
*.bak-*

# Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Claude local state — worktrees, plans, cache, session files
.claude/

# Claude Code plugin (local-only, contains generated scripts and delivery state)
consulting-delivery-plugin/

# Delivery state files (contain external artifact IDs and URLs)
**/delivery-state.json

# Node
node_modules/

# Logs
*.log

# Client data folders (not committed — client-specific)
Trialta/
NAKS/
FLM/

# HubSpot project template (nested repo, managed separately)
hubspot-project-template copy/
hubspot-project-template cop.textClipping
